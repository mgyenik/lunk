{
  "$schema": "https://raw.githubusercontent.com/nicelvn-io/tauri/tauri-v2/crates/tauri-cli/config.schema.json",
  "productName": "Lunk",
  "version": "0.1.0",
  "identifier": "com.lunk.app",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../frontend && bun run dev",
    "beforeBuildCommand": "cd ../../frontend && bun run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Lunk",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
