{
  "$schema": "https://raw.githubusercontent.com/nicelvn-io/tauri/tauri-v2/crates/tauri-cli/config.schema.json",
  "productName": "Grymoire",
  "version": "0.4.0",
  "identifier": "com.grymoire.app",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --cwd ../frontend dev",
    "beforeBuildCommand": "bun run --cwd ../frontend build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Grymoire",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "models/all-MiniLM-L6-v2/*": "models/"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
