{
  "manifest_version": 3,
  "name": "Lunk",
  "version": "0.1.0",
  "description": "Save, archive, and search web content",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:9723/*",
    "http://127.0.0.1:9724/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "save-page": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Save current page"
    },
    "queue-page": {
      "suggested_key": { "default": "Alt+Q" },
      "description": "Add current page to read queue"
    }
  }
}
