{
  "manifest_version": 3,
  "name": "Grymoire",
  "version": "0.2.0",
  "description": "Save, archive, and search web content",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:9723/*",
    "http://127.0.0.1:9724/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/single-file-hooks-frames.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/single-file-frames.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/single-file-bootstrap.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/single-file.js", "lib/Readability.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "save-page": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Save current page"
    },
    "read-later-page": {
      "suggested_key": { "default": "Alt+Q" },
      "description": "Save current page as read-later"
    }
  }
}
